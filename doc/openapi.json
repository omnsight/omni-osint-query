    "/entity/neighbors": {
      "get": {
        "tags": [
          "query"
        ],
        "summary": "Query Neighbors",
        "operationId": "query_neighbors",
        "parameters": [
          {
            "name": "id",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "pattern": "^[A-Za-z0-9_-]+\\/[A-Za-z0-9_-]+$",
              "description": "The ArangoDB Document ID (e.g., collection/123)",
              "title": "Id"
            },
            "description": "The ArangoDB Document ID (e.g., collection/123)"
          },
          {
            "name": "limit",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "description": "The maximum number of results to return.",
              "default": 30,
              "title": "Limit"
            },
            "description": "The maximum number of results to return."
          },
          {
            "name": "offset",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "description": "The offset from which to start returning results.",
              "default": 0,
              "title": "Offset"
            },
            "description": "The offset from which to start returning results."
          },
          {
            "name": "include",
            "in": "query",
            "required": false,
            "schema": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "description": "A list of entity types to include.",
              "title": "Include"
            },
            "description": "A list of entity types to include."
          },
          {
            "name": "exclude",
            "in": "query",
            "required": false,
            "schema": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "description": "A list of entity types to exclude.",
              "title": "Exclude"
            },
            "description": "A list of entity types to exclude."
          },
          {
            "name": "authorization",
            "in": "header",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "title": "Authorization"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/NeighborsResponse"
