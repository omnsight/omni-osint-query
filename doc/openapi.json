    "/events/query": {
      "get": {
        "tags": [
          "query"
        ],
        "summary": "Query Events",
        "operationId": "query_events",
        "parameters": [
          {
            "name": "query",
            "in": "query",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "description": "The search query string.",
              "title": "Query"
            },
            "description": "The search query string."
          },
          {
            "name": "date_start",
            "in": "query",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "integer"
                },
                {
                  "type": "null"
                }
              ],
              "description": "The start of the date range for the query.",
              "title": "Date Start"
            },
            "description": "The start of the date range for the query."
          },
          {
            "name": "date_end",
            "in": "query",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "integer"
                },
                {
                  "type": "null"
                }
              ],
              "description": "The end of the date range for the query.",
              "title": "Date End"
            },
            "description": "The end of the date range for the query."
          },
          {
            "name": "country_code",
            "in": "query",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "description": "The country code to filter the query by.",
              "title": "Country Code"
            },
            "description": "The country code to filter the query by."
          },
          {
            "name": "limit",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "description": "The maximum number of results to return.",
              "default": 30,
              "title": "Limit"
            },
            "description": "The maximum number of results to return."
          },
          {
            "name": "offset",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "description": "The offset from which to start returning results.",
              "default": 0,
              "title": "Offset"
            },
            "description": "The offset from which to start returning results."
          },
          {
            "name": "authorization",
            "in": "header",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "title": "Authorization"
            }
